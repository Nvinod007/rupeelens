# Copy to .env at repo root: cp .env.example .env
# Never commit .env (secrets stay local).

# ——— Backend (rupeelens-be) ———
PORT=3001

# Postgres (when you add Prisma)
# DATABASE_URL=postgresql://rupeelens:rupeelens@localhost:5432/rupeelens

# Setu Account Aggregator (empty = mock mode in API code)
# SETU_AA_BASE_URL=https://fiu-sandbox.setu.co
# SETU_AA_CLIENT_ID=
# SETU_AA_CLIENT_SECRET=
# SETU_WEBHOOK_SECRET=
# SETU_CONSENT_REDIRECT_URL=http://localhost:3000

# ——— Frontend (rupeelens-fe) ———
# Also copy NEXT_PUBLIC_* to apps/rupeelens-fe/.env.local for Next.js
NEXT_PUBLIC_API_URL=http://localhost:3001/api
