# Copy to apps/rupeelens-be/.env (or repo root .env — ConfigModule checks both).
# Never commit .env (secrets stay local).

PORT=3001

# CORS origin for the Next.js app (comma not supported — single URL)
FRONTEND_URL=http://localhost:3000

DATABASE_URL=postgresql://rupeelens:rupeelens@localhost:5432/rupeelens

# Supabase — same project as FE; used by Nest to verify access tokens
SUPABASE_URL=YOUR_SUPABASE_PROJECT_URL
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# Primary data paths: CSV, email parse/sync, SMS (no Setu required)

# Optional Setu AA integration (disabled by default)
ENABLE_SETU=false

# Email IMAP sync (optional — POST /api/imports/email/sync)
# Single-mailbox only: signed-in user email must match EMAIL_IMAP_USER
EMAIL_IMAP_ENABLED=false
EMAIL_IMAP_HOST=imap.gmail.com
EMAIL_IMAP_PORT=993
EMAIL_IMAP_USER=
EMAIL_IMAP_PASSWORD=
# Comma-separated sender addresses/domains to match
EMAIL_IMAP_SENDERS=alerts@hdfcbank.net,no-reply@icicibank.com

# SMS webhook: phone forwarders send x-import-key header (GET /api/auth/import-key)
SMS_WEBHOOK_RATE_LIMIT_PER_MINUTE=60
