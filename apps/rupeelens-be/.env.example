# Copy to apps/rupeelens-be/.env (or repo root .env — ConfigModule checks both).
# Never commit .env (secrets stay local).

PORT=3001

DATABASE_URL=postgresql://rupeelens:rupeelens@localhost:5432/rupeelens

# Supabase — same project as FE; used by Nest to verify access tokens
SUPABASE_URL=YOUR_SUPABASE_PROJECT_URL
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# Setu Account Aggregator (empty = mock mode in API code)
# SETU_AA_BASE_URL=https://fiu-sandbox.setu.co
# SETU_AA_CLIENT_ID=
# SETU_AA_CLIENT_SECRET=
# SETU_WEBHOOK_SECRET=
# SETU_CONSENT_REDIRECT_URL=http://localhost:3000
